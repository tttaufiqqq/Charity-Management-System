APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==============================================================================
# DISTRIBUTED DATABASE CONFIGURATION
# ==============================================================================
# This application uses a heterogeneous distributed database architecture
# with 5 database nodes across different database systems.
# ==============================================================================

# Default Database Connection (Primary Node - Izzhilmy)
# Used for authentication, sessions, cache, jobs, and migrations
DB_CONNECTION=izzhilmy

# ------------------------------------------------------------------------------
# NODE 1: Hannah (MySQL) - Donations & Allocations
# Tables: donor, donation, donation_allocation
# ------------------------------------------------------------------------------
DB1_HOST=127.0.0.1
DB1_PORT=3306
DB1_DATABASE=charity_hannah
DB1_USERNAME=hannah
DB1_PASSWORD=hannah_password_2024

# ------------------------------------------------------------------------------
# NODE 2: Adam (MySQL) - Public & Recipients
# Tables: public, recipient
# ------------------------------------------------------------------------------
DB2_HOST=127.0.0.1
DB2_PORT=3307
DB2_DATABASE=charity_adam
DB2_USERNAME=adam
DB2_PASSWORD=adam_password_2024

# ------------------------------------------------------------------------------
# NODE 3: Sashvini (MariaDB) - Volunteer Management
# Tables: volunteer, volunteer_skill, skill, event_participation
# Note: Connection name 'sahsvini' in config/database.php
# ------------------------------------------------------------------------------
DB3_HOST=127.0.0.1
DB3_PORT=3308
DB3_DATABASE=charity_sashvini
DB3_USERNAME=sahsvini
DB3_PASSWORD=sashvini_password_2024

# ------------------------------------------------------------------------------
# NODE 4: Izati (PostgreSQL) - Organization & Events
# Tables: organization, event, campaign, event_role
# ------------------------------------------------------------------------------
DB4_HOST=127.0.0.1
DB4_PORT=5433
DB4_DATABASE=charity_izati
DB4_USERNAME=izati
DB4_PASSWORD=izati_password_2024

# ------------------------------------------------------------------------------
# NODE 5: Izzhilmy (PostgreSQL) - Authentication & Authorization (PRIMARY)
# Tables: users, roles, model_has_roles, permissions, sessions, cache, jobs, migrations
# ------------------------------------------------------------------------------
DB5_HOST=127.0.0.1
DB5_PORT=5432
DB5_DATABASE=charity_izzhilmy
DB5_USERNAME=izzhilmy
DB5_PASSWORD=izzhilmy_password_2024

# ==============================================================================
# DEPLOYMENT NOTES:
# - For Docker local testing: Use localhost (127.0.0.1) with ports as shown above
# - For Docker cross-machine: Replace 127.0.0.1 with actual server IP addresses
# - For production: Use environment-specific hosts and strong passwords
# - Ensure firewall rules allow communication between nodes
# ==============================================================================


SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ToyyibPay Payment Gateway Configuration
# Get your credentials from https://dev.toyyibpay.com or https://toyyibpay.com
TOYYIBPAY_SECRET_KEY=your-secret-key-here
TOYYIBPAY_CATEGORY_CODE=your-category-code-here
TOYYIBPAY_SANDBOX=true
